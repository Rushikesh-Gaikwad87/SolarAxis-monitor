{
  "brand": "Waaree",
  "model": "WRS Series",
  "protocol": "tcp",
  "ip_port": 502,
  "slave_id": 1,
  "poll_interval": 5,
  "registers": {
    "pv_voltage":   {"addr": 40001, "type": "uint16", "scale": 0.1},
    "pv_current":   {"addr": 40002, "type": "uint16", "scale": 0.1},
    "pv_power":     {"addr": 40003, "type": "uint32", "scale": 0.1},
    "grid_voltage": {"addr": 40007, "type": "uint16", "scale": 0.1},
    "grid_current": {"addr": 40008, "type": "uint16", "scale": 0.1},
    "frequency":    {"addr": 40009, "type": "uint16", "scale": 0.01},
    "today_energy": {"addr": 40013, "type": "uint16", "scale": 0.1},
    "total_energy": {"addr": 40015, "type": "uint32", "scale": 0.1},
    "temperature":  {"addr": 40017, "type": "int16",  "scale": 0.1},
    "status":       {"addr": 40025, "type": "uint16", "scale": 1}
  }
}
