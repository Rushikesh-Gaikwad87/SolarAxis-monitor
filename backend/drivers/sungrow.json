{
  "brand": "Sungrow",
  "model": "SG Series",
  "protocol": "tcp",
  "ip_port": 502,
  "slave_id": 1,
  "poll_interval": 5,
  "registers": {
    "pv_voltage":   {"addr": 5011, "type": "uint16", "scale": 0.1},
    "pv_current":   {"addr": 5012, "type": "uint16", "scale": 0.1},
    "pv_power":     {"addr": 5031, "type": "uint32", "scale": 0.1},
    "grid_voltage": {"addr": 5019, "type": "uint16", "scale": 0.1},
    "grid_current": {"addr": 5020, "type": "uint16", "scale": 0.1},
    "frequency":    {"addr": 5036, "type": "uint16", "scale": 0.01},
    "today_energy": {"addr": 5003, "type": "uint16", "scale": 0.1},
    "total_energy": {"addr": 5004, "type": "uint32", "scale": 1},
    "temperature":  {"addr": 5041, "type": "int16",  "scale": 0.1},
    "status":       {"addr": 5038, "type": "uint16", "scale": 1}
  }
}
