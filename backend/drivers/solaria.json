{
  "brand": "Solaria",
  "model": "SPower Series",
  "protocol": "tcp",
  "ip_port": 502,
  "slave_id": 1,
  "poll_interval": 5,
  "registers": {
    "pv_voltage":   {"addr": 6001, "type": "uint16", "scale": 0.1},
    "pv_current":   {"addr": 6002, "type": "uint16", "scale": 0.1},
    "pv_power":     {"addr": 6003, "type": "uint32", "scale": 0.1},
    "grid_voltage": {"addr": 6007, "type": "uint16", "scale": 0.1},
    "grid_current": {"addr": 6008, "type": "uint16", "scale": 0.1},
    "frequency":    {"addr": 6009, "type": "uint16", "scale": 0.01},
    "today_energy": {"addr": 6013, "type": "uint16", "scale": 0.1},
    "total_energy": {"addr": 6015, "type": "uint32", "scale": 0.1},
    "temperature":  {"addr": 6017, "type": "int16",  "scale": 0.1},
    "status":       {"addr": 6025, "type": "uint16", "scale": 1}
  }
}
